# Comma-separated list of origins allowed to make cross-origin requests to the server.
# Required when the client is served from a different origin (e.g. Vercel).
# Leave blank when the client is served from the same server (default Docker setup).
ALLOWED_ORIGIN=https://polka-zeta.vercel.app

# Host port the server API is exposed on (default 3001).
# Only needed when the client is served externally and needs direct API access.
SERVER_PORT=3001

# Required on Node.js 17+ — NTLM (used by SMB) relies on MD4 which OpenSSL 3
# disabled by default.
NODE_OPTIONS=--openssl-legacy-provider

# TLS certificate files for HTTPS. Obtain via: tailscale cert <hostname>
# When set, the server listens on HTTPS instead of HTTP.
# Leave blank for plain HTTP (local dev or same-origin Docker setup).
TLS_KEY_FILE=/path/to/hostname.ts.net.key
TLS_CERT_FILE=/path/to/hostname.ts.net.crt
