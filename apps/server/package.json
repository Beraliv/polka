{
  "name": "@polka/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--openssl-legacy-provider node --watch --experimental-strip-types src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "ALLOWED_ORIGIN=https://polka-zeta.vercel.app NODE_OPTIONS=--openssl-legacy-provider node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.0.3",
    "@marsaud/smb2": "^0.18.0",
    "@polka/shared": "workspace:*",
    "fastify": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
