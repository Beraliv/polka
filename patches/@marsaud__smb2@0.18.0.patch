diff --git a/lib/messages/query_info.js b/lib/messages/query_info.js
new file mode 100644
index 0000000000000000000000000000000000000000..3bcfd6f4f39a1beac45800cb68e17826d9f53b68
--- /dev/null
+++ b/lib/messages/query_info.js
@@ -0,0 +1,25 @@
+var SMB2Message = require('../tools/smb2-message');
+var message = require('../tools/message');
+
+module.exports = message({
+  generate: function(connection, params) {
+    return new SMB2Message({
+      headers: {
+        Command: 'QUERY_INFO',
+        SessionId: connection.SessionId,
+        TreeId: connection.TreeId,
+        ProcessId: connection.ProcessId,
+      },
+      request: {
+        FileId: params.FileId,
+      },
+    });
+  },
+
+  parseResponse: function(response) {
+    // FileStandardInformation layout: AllocationSize(8) EndOfFile(8) ...
+    // Return the EndOfFile bytes (offset 8-15) from the output buffer.
+    var buf = response.getResponse().Buffer;
+    return buf.slice(8, 16);
+  },
+});
