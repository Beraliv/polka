+/*
+ * Extended Type2 decode that returns both the server challenge and
+ * the TargetInfo blob (required for NTLMv2 response computation).
+ */
+function decodeType2v2(buf) {
+  var proto = buf.toString('ascii', 0, 7);
+  if (buf[7] !== 0x00 || proto !== 'NTLMSSP')
+    throw new Error('magic was not NTLMSSP');
+
+  var type = buf.readUInt8(8);
+  if (type !== 0x02)
+    throw new Error('message was not NTLMSSP type 0x02');
+
+  var nonce = buf.slice(24, 32);
+
+  // TargetInfo fields at offset 40 (Len:2 + MaxLen:2 + Offset:4)
+  var targetInfo = Buffer.alloc(0);
+  if (buf.length > 47) {
+    var tiLen = buf.readUInt16LE(40);
+    var tiOffset = buf.readUInt32LE(44);
+    if (tiLen > 0 && tiOffset > 0 && tiOffset + tiLen <= buf.length) {
+      targetInfo = buf.slice(tiOffset, tiOffset + tiLen);
+    }
+  }
+
+  return { nonce: nonce, targetInfo: targetInfo };
+}
